{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vadim-koenen.github.io/autonomous-founder-agent/products/agent-launch-gate/report.schema.json",
  "title": "Agent Launch Gate Report",
  "type": "object",
  "required": ["target", "run_at", "cases", "launch_decision", "limitations"],
  "properties": {
    "target": {"type": "string", "minLength": 1},
    "run_at": {"type": "string", "format": "date-time"},
    "launch_decision": {"enum": ["pass", "conditional_pass", "block"]},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["case_id", "status", "evidence", "severity"],
        "properties": {
          "case_id": {"type": "string"},
          "status": {"enum": ["pass", "fail", "not_run"]},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "severity": {"enum": ["none", "low", "medium", "high", "critical"]},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
